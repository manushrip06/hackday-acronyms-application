# Environment template — copy to `.env` at repo root (and/or apps/*)

# Hackday auth (no real login)
# Send headers: X-Role: lead|member  and optional X-User: yourname

# API
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./data/acronyms.db
TEAM_ID=default
UPLOAD_DIR=./data/uploads
NLP_URL=http://127.0.0.1:8001
USE_MOCK_NLP=false

# NLP service
NLP_HOST=0.0.0.0
NLP_PORT=8001
# Optional — without a key, heuristic definitions are used
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Or Azure OpenAI:
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
