    "name": "Hackday Acronyms Team",
    "websiteUrl": "https://localhost:3000",
    "privacyUrl": "https://localhost:3000",
    "termsOfUseUrl": "https://localhost:3000"
  },
  "name": {
    "short": "Acronym Atlas",
    "full": "Acronym Atlas — team jargon dictionary"
  },
  "description": {
    "short": "Look up team-specific acronyms from your docs.",
    "full": "Leads upload documentation; AI extracts jargon into a reviewable dictionary. Members click unclear terms in the Lookup tab to see definitions. Sideload for hackday — no AppSource required."
  },
