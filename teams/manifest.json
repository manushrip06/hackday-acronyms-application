      "scopes": ["personal"]
    },
    {
      "entityId": "dictionary",
      "name": "Dictionary",
      "contentUrl": "https://REPLACE_WITH_HTTPS_TUNNEL/dictionary",
      "websiteUrl": "https://REPLACE_WITH_HTTPS_TUNNEL/dictionary",
      "scopes": ["personal"]
    },
    {
      "entityId": "upload",
      "name": "Upload",
      "contentUrl": "https://REPLACE_WITH_HTTPS_TUNNEL/upload",
      "websiteUrl": "https://REPLACE_WITH_HTTPS_TUNNEL/upload",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["REPLACE_WITH_HTTPS_TUNNEL_HOST"]
